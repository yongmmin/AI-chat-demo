{
  "name": "ai-chat-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "npx tsx server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "postinstall": "cd server && npm install",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:easy": "vitest run src/__test__/App.easy.spec.tsx",
    "test:hard": "vitest run src/__test__/App.hard.spec.tsx",
    "test:server": "cd server && npm test",
    "test:all": "npm test && npm run test:server"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
